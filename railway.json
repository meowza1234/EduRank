{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "find . -name '*.pyc' -delete && pip install -r backend/requirements.txt"
  },
  "deploy": {
    "startCommand": "cd backend && gunicorn wsgi:app",
    "restartPolicyType": "ON_FAILURE"
  }
}
